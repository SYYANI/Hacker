<head>
  <meta charset="utf-8" />
  <%
    function toPlainText(value) {
      return strip_html(value || '').replace(/\s+/g, ' ').trim();
    }

    var title = [];
    if (page.title) {
      title.push(page.title);
    } else if (page.tag) {
      title.push('#' + page.tag);
    } else if (page.category) {
      title.push('#' + page.category);
    } else if (page.archive) {
      if (page.year) {
        title.push(__('archive_b', page.year + (page.month ? '/' + page.month : '')));
      } else {
        title.push('All Posts');
      }
    }
    if (page.current > 1) {
      title.unshift(__('page', page.current));
    }
    title.push(config.title);

    var description = '';
    if (page.description) description = toPlainText(page.description);
    else if (page.excerpt) description = toPlainText(page.excerpt);
    else if (page.content) description = toPlainText(page.content).slice(0, 180);
    else if (config.description) description = toPlainText(config.description);
    else if (config.subtitle) description = toPlainText(config.subtitle);
  %>
  <title><%= title.join(' - ') %></title>

  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <% if (config.author) { %>
  <meta name="author" content="<%= config.author %>" />
  <% } %>

  <% if (description) { %>
  <meta name="description" content="<%= description %>" />
  <% } %>

  <% if (page.keywords) { %>
  <meta name="keywords" content="<%= page.keywords %><% if (config.keywords) { %>,<%= config.keywords %><% } %>" />
  <% } else if (config.keywords) { %>
  <meta name="keywords" content="<%= config.keywords %>" />
  <% } else if (page.tags) { %>
  <%
    var keywords = [];
    page.tags.forEach(function(tag){
      keywords.push(tag.name);
    });
  %>
  <% if (keywords.length) { %>
  <meta name="keywords" content="<%= keywords.join(',') %>" />
  <% } %>
  <% } %>

  <meta property="og:site_name" content="<%= config.title %>" />
  <meta property="og:title" content="<%= page.title || config.title %>" />
  <% if (description) { %>
  <meta property="og:description" content="<%= description %>" />
  <% } %>
  <% if (page.permalink) { %>
  <meta property="og:url" content="<%= page.permalink %>" />
  <% } %>
  <% if (page.cover) { %>
  <meta property="og:image" content="<%= page.cover %>" />
  <% } else if (config.cover) { %>
  <meta property="og:image" content="<%= config.cover %>" />
  <% } %>
  <%
    var feedPath = 'atom.xml';
    if (config.feed && config.feed.path) {
      feedPath = config.feed.path;
    } else if (theme.rss) {
      feedPath = theme.rss;
    }
  %>
  <link rel="icon" href="<%- url_for('/favicon.ico') %>" />
  <link rel="alternate" type="application/atom+xml" href="<%- url_for(feedPath) %>" title="<%= config.title %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@400;700&family=Ruda:wght@400;600;700&display=swap" />
  <link rel="stylesheet" href="<%- url_for('/css/style.css') %>" media="screen" type="text/css" />
</head>
