<article>
  <h1><%= page.title %></h1>

  <%- partial('components/post_meta', { item: page }) %>

  <%- page.content %>
</article>

<% if (page.prev || page.next) { %>
<section class="post-nav">
  <ul>
    <li>
      <% if (page.prev) { %>
        <a href="<%- url_for(page.prev.path) %>">&lsaquo; <%= page.prev.title %></a>
      <% } %>
    </li>
    <li>
      <% if (page.next) { %>
        <a href="<%- url_for(page.next.path) %>"><%= page.next.title %> &rsaquo;</a>
      <% } %>
    </li>
  </ul>
</section>
<% } %>

<% if (page.comments !== false) { %>
  <%- partial('components/comment', { item: page }) %>
<% } %>
